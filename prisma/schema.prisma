generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model RoyaltyScan {
  id         String   @id @default(cuid())
  artistId   String
  status     String
  progress   Int      @default(0)
  message    String?
  resultJson Json?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
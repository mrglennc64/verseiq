generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model RoyaltyScan {
  id         String   @id @default(cuid())
  artistId   String
  status     String
  progress   Int      @default(0)
  message    String?
  resultJson Json?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Tenant {
  id        String          @id @default(cuid())
  slug      String          @unique
  name      String
  createdAt DateTime        @default(now())
  settings  TenantSettings?
}

model TenantSettings {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultRepName       String?
  defaultRepEntity     String?
  defaultFeePercent    Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Artist {
  id              String      @id @default(cuid())
  tenantId        String      @default("default")
  legalName       String
  stageName       String?
  address         String?
  email           String?
  soundexchangeId String?
  mlcId           String?
  proAffiliation  String?
  createdAt       DateTime    @default(now())
  recordings      Recording[]

  @@index([tenantId])
}

model Recording {
  id             String          @id @default(cuid())
  tenantId       String          @default("default")
  artistId       String
  artist         Artist          @relation(fields: [artistId], references: [id], onDelete: Cascade)
  isrc           String
  title          String
  releaseDate    DateTime?
  label          String?
  upc            String?
  createdAt      DateTime        @default(now())
  splits         Split[]
  statementLines StatementLine[]

  @@index([tenantId])
  @@index([artistId])
  @@unique([tenantId, isrc])
}

model Split {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  recordingId     String
  recording       Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  participantName String
  role            String
  percentage      Float
  createdAt       DateTime  @default(now())

  @@index([tenantId])
  @@index([recordingId])
}

model Statement {
  id             String          @id @default(cuid())
  tenantId       String          @default("default")
  sourcePlatform String          // "soundexchange" | "mlc" | "distrokid" | "generic" | ...
  sourceFilename String
  uploadedAt     DateTime        @default(now())
  totalRows      Int             @default(0)
  matchedRows    Int             @default(0)
  unmatchedRows  Int             @default(0)
  totalAmount    Float           @default(0)
  unmatchedAmount Float          @default(0)
  currency       String          @default("USD")
  notes          String?
  lines          StatementLine[]

  @@index([tenantId])
  @@index([sourcePlatform])
}

model StatementLine {
  id          String    @id @default(cuid())
  tenantId    String    @default("default")
  statementId String
  statement   Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  recordingId String?
  recording   Recording? @relation(fields: [recordingId], references: [id])
  rawIsrc     String?
  rawTitle    String?
  rawArtist   String?
  rawPeriod   String?
  amount      Float     @default(0)
  matched     Boolean   @default(false)
  rawRow      Json

  @@index([tenantId])
  @@index([statementId])
  @@index([recordingId])
  @@index([matched])
}

model Lod {
  id                    String       @id @default(cuid())
  tenantId              String       @default("default")
  artistLegalName       String
  artistAddress         String
  artistEmail           String
  representativeName    String
  representativeEntity  String
  feePercent            Float
  isrcs                 Json
  pdfPath               String
  pdfHash               String
  createdAt             DateTime     @default(now())
  submissions           Submission[]

  @@index([tenantId])
}

model Submission {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  lodId       String?
  lod         Lod?     @relation(fields: [lodId], references: [id])
  platform    String   // "soundexchange" | "mlc" | "pro"
  packetPath  String
  status      String   @default("submitted")
  note        String?
  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([tenantId])
}
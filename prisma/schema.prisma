generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model RoyaltyScan {
  id         String   @id @default(cuid())
  artistId   String
  status     String
  progress   Int      @default(0)
  message    String?
  resultJson Json?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Tenant {
  id        String          @id @default(cuid())
  slug      String          @unique
  name      String
  createdAt DateTime        @default(now())
  settings  TenantSettings?
}

model TenantSettings {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultRepName       String?
  defaultRepEntity     String?
  defaultFeePercent    Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Artist {
  id              String      @id @default(cuid())
  tenantId        String      @default("default")
  // Owning user account. Nullable because legacy demo artists were seeded
  // before auth existed. New artists created via the signup flow will always
  // have this set.
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  legalName       String
  stageName       String?
  address         String?
  email           String?
  soundexchangeId String?
  mlcId           String?
  proAffiliation  String?
  // External catalog source IDs — nullable, non-unique (same artist may exist on multiple platforms).
  // Used by the royalty-recovery scan pipeline and future Deezer/MusicBrainz catalog sources.
  spotifyArtistId String?
  deezerArtistId  String?
  musicbrainzId   String?
  // SoundExchange intake fields — collected in the SE Assistant. Nullable so existing
  // rows (and artists from other flows) stay valid.
  dateOfBirth     DateTime?
  countryCode     String?
  bankCountryCode String?
  primaryGenre    String?
  createdAt       DateTime    @default(now())
  recordings      Recording[]
  registrationStatuses RegistrationStatus[]
  reminderLogs         ReminderLog[]
  soundexchangePackets SoundexchangePacket[]

  @@index([tenantId])
  @@index([userId])
  @@index([spotifyArtistId])
  @@index([deezerArtistId])
  @@index([musicbrainzId])
}

// ---------------------------------------------------------------------------
// NextAuth (Auth.js) models — standard shape required by @auth/prisma-adapter.
// Do not add fields to these models inline; if extension is needed, create a
// related 1:1 model (e.g. UserProfile) instead so the adapter stays happy.
// ---------------------------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Hashed password for the Credentials provider. Null when the user only
  // uses OAuth providers (Google/Apple/etc., added later).
  passwordHash  String?
  role          String    @default("artist") // artist | manager | label | publisher | admin
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  artists  Artist[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Current registration state for an artist at a given organization.
// One row per (artist, org). Updated in place by hooks or admin actions.
// Status values (see lib/registration/status.ts for constants):
//   NOT_STARTED, INTAKE_IN_PROGRESS, PACKET_GENERATED,
//   ARTIST_ACTION_REQUIRED, SUBMITTED, VERIFIED, ACTIVE
// Org values:
//   SOUNDEXCHANGE, MLC, ASCAP, BMI, SOCAN, PRS, GMR
model RegistrationStatus {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  artistId  String
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  org       String
  status    String   @default("NOT_STARTED")
  note      String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([artistId, org])
  @@index([tenantId])
  @@index([org])
  @@index([status])
}

// Audit log of reminders sent from the admin dashboard. Email delivery is stubbed
// for now — rows here track intent, not confirmed delivery.
model ReminderLog {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  artistId  String
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  org       String
  channel   String   @default("email") // "email" | "in-app" | "manual"
  note      String?
  sentBy    String?
  sentAt    DateTime @default(now())

  @@index([tenantId])
  @@index([artistId])
  @@index([org])
}

// Generated SoundExchange packet for an artist. One artist can have multiple
// packets over time (e.g., regenerated after catalog changes) — we keep the
// full history and the app resolves "latest" via generatedAt desc.
//
// Packet status lifecycle:
//   DRAFT         — rows exist but packet files not yet generated
//   GENERATED     — files written, ready for artist download
//   SUBMITTED     — artist confirmed they submitted to SoundExchange
//   VERIFIED      — SE confirmed registration (manual or future webhook)
model SoundexchangePacket {
  id             String   @id @default(cuid())
  tenantId       String   @default("default")
  artistId       String
  artist         Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  status         String   @default("DRAFT")
  lodBundlePath  String?  // path to bundled LODs (zip or single PDF)
  catalogCsvPath String?  // path to catalog CSV
  summaryPdfPath String?  // path to cover-sheet/summary PDF
  hash           String?  // sha256 of the packet contents for change detection
  note           String?
  generatedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([artistId])
  @@index([status])
}

model Recording {
  id             String          @id @default(cuid())
  tenantId       String          @default("default")
  artistId       String
  artist         Artist          @relation(fields: [artistId], references: [id], onDelete: Cascade)
  isrc           String
  title          String
  releaseDate    DateTime?
  label          String?
  upc            String?
  createdAt      DateTime        @default(now())
  splits         Split[]
  statementLines StatementLine[]

  @@index([tenantId])
  @@index([artistId])
  @@unique([tenantId, isrc])
}

model Split {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  recordingId     String
  recording       Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  participantName String
  role            String
  percentage      Float
  createdAt       DateTime  @default(now())

  @@index([tenantId])
  @@index([recordingId])
}

model Statement {
  id             String          @id @default(cuid())
  tenantId       String          @default("default")
  sourcePlatform String          // "soundexchange" | "mlc" | "distrokid" | "generic" | ...
  sourceFilename String
  uploadedAt     DateTime        @default(now())
  totalRows      Int             @default(0)
  matchedRows    Int             @default(0)
  unmatchedRows  Int             @default(0)
  totalAmount    Float           @default(0)
  unmatchedAmount Float          @default(0)
  currency       String          @default("USD")
  notes          String?
  lines          StatementLine[]

  @@index([tenantId])
  @@index([sourcePlatform])
}

model StatementLine {
  id          String    @id @default(cuid())
  tenantId    String    @default("default")
  statementId String
  statement   Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  recordingId String?
  recording   Recording? @relation(fields: [recordingId], references: [id])
  rawIsrc     String?
  rawTitle    String?
  rawArtist   String?
  rawPeriod   String?
  amount      Float     @default(0)
  matched     Boolean   @default(false)
  rawRow      Json

  @@index([tenantId])
  @@index([statementId])
  @@index([recordingId])
  @@index([matched])
}

model Lod {
  id                    String       @id @default(cuid())
  tenantId              String       @default("default")
  artistLegalName       String
  artistAddress         String
  artistEmail           String
  representativeName    String
  representativeEntity  String
  feePercent            Float
  isrcs                 Json
  pdfPath               String
  pdfHash               String
  createdAt             DateTime     @default(now())
  submissions           Submission[]

  @@index([tenantId])
}

model Submission {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  lodId       String?
  lod         Lod?     @relation(fields: [lodId], references: [id])
  platform    String   // "soundexchange" | "mlc" | "pro"
  packetPath  String
  status      String   @default("submitted")
  note        String?
  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([tenantId])
}